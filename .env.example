# URL Shortener Application Configuration

# Server configuration
SERVER_PORT=8080
PORT=8080

# Redis configuration
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# Security configuration
REQUIRE_HTTPS=false
RATE_LIMIT_PER_DAY=1000
RATE_LIMIT_WINDOW_HOURS=24
API_KEY_PREFIX=sk_live_
MAX_URL_LENGTH=2048

# Admin configuration (for API key generation endpoint)
ADMIN_API_KEY=your_admin_key_here

# MongoDB configuration (for analytics)
MONGODB_URI=mongodb://mongo:27017
MONGODB_DB=url_shortener

# Analytics configuration
ANALYTICS_ENABLED=true
METRICS_RETENTION_DAYS=30
BATCH_WRITE_INTERVAL_MINUTES=5
AGGREGATION_INTERVAL_MINUTES=60
